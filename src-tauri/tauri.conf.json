{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Moira",
  "version": "0.1.0",
  "identifier": "pl.hycom.moira",
  "build": {
    "frontendDist": "../cockpit/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../cockpit run dev",
    "beforeBuildCommand": "npm --prefix ../cockpit run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
